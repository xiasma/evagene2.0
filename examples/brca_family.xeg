<?xml version="1.0" encoding="utf-8"?>
<!--
  BRCAPRO Example: Hereditary Breast & Ovarian Cancer Family

  Three-generation family with strong history of breast and ovarian cancer.
  The proband (Sarah, age 42) is unaffected but has a mother and maternal
  aunt with breast cancer, and a maternal grandmother with ovarian cancer.

  Demonstrates: BRCAPRO risk analysis for BRCA1/BRCA2 carrier probability
  and future breast/ovarian cancer risk.
-->
<Pedigree>
  <StudyDiseases>
    <StudyDisease>
      <Guid>disease-breast</Guid>
      <Name>Breast Cancer</Name>
      <Colour><R>255</R><G>105</G><B>180</B></Colour>
    </StudyDisease>
    <StudyDisease>
      <Guid>disease-ovarian</Guid>
      <Name>Ovarian Cancer</Name>
      <Colour><R>123</R><G>104</G><B>238</B></Colour>
    </StudyDisease>
  </StudyDiseases>

  <Individuals>
    <!-- Generation I (Grandparents) -->

    <!-- Maternal Grandmother: Margaret — ovarian cancer at 58, died at 65 -->
    <Individual>
      <Guid>ind-margaret</Guid>
      <Name>Margaret Wilson</Name>
      <Sex>Female</Sex>
      <Generation>0</Generation>
      <X>200</X><Y>100</Y>
      <Living>Dead</Living>
      <Affection>Affected</Affection>
      <DefinedFields>
        <DefinedField><Name>Surname</Name><Value>Wilson</Value></DefinedField>
        <DefinedField><Name>Given names</Name><Value>Margaret</Value></DefinedField>
      </DefinedFields>
      <Events>
        <Event><Status>NaturalDelivery</Status><Date>01/03/1940 00:00:00</Date><Name>Birth</Name></Event>
        <Event><Status>Diagnosis</Status><Date>15/06/1998 00:00:00</Date><Name>Ovarian cancer diagnosis</Name></Event>
        <Event><Status>Death</Status><Date>20/11/2005 00:00:00</Date><Name>Death</Name></Event>
      </Events>
      <Manifestations>
        <Manifestation StudyDiseaseRef="disease-ovarian" />
      </Manifestations>
    </Individual>

    <!-- Maternal Grandfather: Robert — unaffected, age 88 -->
    <Individual>
      <Guid>ind-robert</Guid>
      <Name>Robert Wilson</Name>
      <Sex>Male</Sex>
      <Generation>0</Generation>
      <X>400</X><Y>100</Y>
      <Living>Alive</Living>
      <DefinedFields>
        <DefinedField><Name>Surname</Name><Value>Wilson</Value></DefinedField>
        <DefinedField><Name>Given names</Name><Value>Robert</Value></DefinedField>
      </DefinedFields>
      <Events>
        <Event><Status>NaturalDelivery</Status><Date>14/07/1937 00:00:00</Date><Name>Birth</Name></Event>
      </Events>
    </Individual>

    <!-- Paternal Grandmother: Dorothy — unaffected, age 85 -->
    <Individual>
      <Guid>ind-dorothy</Guid>
      <Name>Dorothy Chen</Name>
      <Sex>Female</Sex>
      <Generation>0</Generation>
      <X>700</X><Y>100</Y>
      <Living>Alive</Living>
      <DefinedFields>
        <DefinedField><Name>Surname</Name><Value>Chen</Value></DefinedField>
        <DefinedField><Name>Given names</Name><Value>Dorothy</Value></DefinedField>
      </DefinedFields>
      <Events>
        <Event><Status>NaturalDelivery</Status><Date>22/09/1940 00:00:00</Date><Name>Birth</Name></Event>
      </Events>
    </Individual>

    <!-- Paternal Grandfather: William — unaffected, died at 78 -->
    <Individual>
      <Guid>ind-william</Guid>
      <Name>William Chen</Name>
      <Sex>Male</Sex>
      <Generation>0</Generation>
      <X>900</X><Y>100</Y>
