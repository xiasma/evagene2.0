  </Individuals>

  <Marriages>
    <!-- Margaret + Robert (maternal grandparents) -->
    <Marriage>
      <Guid>mar-margaret-robert</Guid>
      <Spouse1Ref>ind-margaret</Spouse1Ref>
      <Spouse2Ref>ind-robert</Spouse2Ref>
    </Marriage>

    <!-- Dorothy + William (paternal grandparents) -->
    <Marriage>
      <Guid>mar-dorothy-william</Guid>
      <Spouse1Ref>ind-dorothy</Spouse1Ref>
      <Spouse2Ref>ind-william</Spouse2Ref>
    </Marriage>

    <!-- Linda + James (parents) -->
    <Marriage>
      <Guid>mar-linda-james</Guid>
      <Spouse1Ref>ind-linda</Spouse1Ref>
