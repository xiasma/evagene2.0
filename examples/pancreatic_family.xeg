<?xml version="1.0" encoding="utf-8"?>
<!--
  PancPRO Example: Familial Pancreatic Cancer Family

  Three-generation family with pancreatic cancer in two relatives.
  The proband (Tom, age 50) is unaffected but has a mother who died of
  pancreatic cancer at 62 and a maternal uncle who was diagnosed at 58.

  Demonstrates: PancPRO risk analysis for PALB2/PANC gene carrier
  probability and future pancreatic cancer risk.
-->
<Pedigree>
  <StudyDiseases>
    <StudyDisease>
      <Guid>disease-pancreatic</Guid>
      <Name>Pancreatic Cancer</Name>
      <Colour><R>75</R><G>0</G><B>130</B></Colour>
    </StudyDisease>
  </StudyDiseases>

