        <DefinedField><Name>Surname</Name><Value>Morgan</Value></DefinedField>
        <DefinedField><Name>Given names</Name><Value>Edith</Value></DefinedField>
      </DefinedFields>
      <Events>
        <Event><Status>NaturalDelivery</Status><Date>16/05/1930 00:00:00</Date><Name>Birth</Name></Event>
