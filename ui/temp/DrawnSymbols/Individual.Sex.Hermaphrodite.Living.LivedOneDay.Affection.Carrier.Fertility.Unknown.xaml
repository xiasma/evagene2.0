<?xml version="1.0" encoding="utf-8"?>
<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:MyNamespace="clr-namespace:Xiasma.WPF;assembly=Xiasma.WPF">
  <Grid.RowDefinitions>
    <RowDefinition Height="15"></RowDefinition>
    <RowDefinition Height="48"></RowDefinition>
    <RowDefinition Height="15"></RowDefinition>
  </Grid.RowDefinitions>
  <Line Name="VerticalAnchors" X1="24" Y1="12" X2="24" Y2="36" Visibility="Hidden" Grid.Row="1" />
  <Line Name="HorizontalAnchors" X1="12" Y1="24" X2="36" Y2="24" Visibility="Hidden" Grid.Row="1" />
  <Line Name="Centre" X1="24" Y1="24" Visibility="Hidden" Grid.Row="1" />
  <Path StrokeDashArray="5 4" Grid.Row="1">
    <Path.Data>
      <PathGeometry>
        <PathFigure StartPoint="12,12" IsClosed="True">
          <PathFigure.Segments>
            <LineSegment Point="36,12" />
            <LineSegment Point="36,36" />
            <LineSegment Point="12,36" />
          </PathFigure.Segments>
        </PathFigure>
      </PathGeometry>
    </Path.Data>
  </Path>
  <Path StrokeDashArray="5 4" Grid.Row="1">
    <Path.Data>
      <EllipseGeometry Center="24,24" RadiusX="10" RadiusY="10" />
    </Path.Data>
  </Path>
  <Path Name="Carrier" Grid.Row="1" >
    <Path.Data>
      <EllipseGeometry Center="24,24" RadiusX="6" RadiusY="6" />
    </Path.Data>
  </Path>
</Grid>