<?xml version="1.0" encoding="utf-8" ?>
<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:MyNamespace="clr-namespace:Xiasma.WPF;assembly=Xiasma.WPF" 
      Width="48" Height="48">
    <Line Name="VerticalAnchors" X1="24" Y1="0" X2="24" Y2="48" Visibility="Hidden"/>
    <Line Name="HorizontalAnchors" X1="0" Y1="24" X2="48" Y2="24" Visibility="Hidden"/>
    <Line Name="Centre" X1="24" Y1="24" Visibility="Hidden"/>
    <Rectangle Margin="0,6,30,12" Width="12">
        <Rectangle.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
                <SkewTransform AngleX="45" AngleY="0"/>
                <RotateTransform Angle="0"/>
                <TranslateTransform X="0" Y="4"/>
            </TransformGroup>
        </Rectangle.RenderTransform>
    </Rectangle>
    <Rectangle Margin="0,6,30,12" Width="12">
        <Rectangle.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
                <SkewTransform AngleX="315" AngleY="0"/>
                <RotateTransform Angle="0"/>
                <TranslateTransform X="30" Y="4"/>
            </TransformGroup>
        </Rectangle.RenderTransform>
    </Rectangle>
</Grid>
